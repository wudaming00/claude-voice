# ---- Server ----
HOST=0.0.0.0
PORT=7878

# ---- Claude ----
# Path to the `claude` executable. Leave blank to auto-discover (PATH first,
# then the VS Code / VS Code Server extension native binary).
# Recommended: `npm install -g @anthropic-ai/claude-code && claude login` and
# leave this blank.
CLAUDE_BIN=

# Working directory Claude operates in. Defaults to your home directory.
# You almost certainly want to scope this to a single project for safety.
# Example: CLAUDE_CWD=/home/you/projects/my-app
CLAUDE_CWD=

# Model override: sonnet | haiku | opus (blank = account default)
CLAUDE_MODEL=

# Permission mode: default | acceptEdits | bypassPermissions | plan
# `bypassPermissions` lets Claude run tools freely — needed for hands-free
# voice use, but Claude can then edit files, run shell commands, and push
# git without prompting. Scope CLAUDE_CWD tightly if you enable this.
CLAUDE_PERMISSION_MODE=bypassPermissions

# ---- Whisper (speech-to-text) ----
# Size: tiny | base | small | medium | large-v3
# large-v3 is most accurate (multilingual + code-switching).
# small/medium are faster; tiny is fastest but poor on non-English.
WHISPER_MODEL=large-v3

# Device: auto | cpu | cuda
WHISPER_DEVICE=auto

# Compute: int8 | int8_float16 | float16 | float32
# float16 is best quality/speed on modern NVIDIA GPUs.
# int8 is a good CPU-only default.
WHISPER_COMPUTE=float16

# Optional: technical vocabulary hint passed to Whisper as initial context.
# Biases recognition toward these tokens (names, product names, jargon).
# WHISPER_INITIAL_PROMPT=A technical conversation about Python, FastAPI, React.

# ---- Edge TTS (text-to-speech) ----
# Full voice list: `edge-tts --list-voices`
# English: en-US-AriaNeural | en-US-GuyNeural | en-GB-SoniaNeural
# Chinese: zh-CN-XiaoxiaoNeural | zh-CN-YunxiNeural | zh-CN-YunyangNeural
# Japanese: ja-JP-NanamiNeural
# Spanish: es-ES-ElviraNeural
EDGE_VOICE=en-US-AriaNeural

# Speaking rate, e.g. +0%, +10%, -20%
EDGE_RATE=+10%
