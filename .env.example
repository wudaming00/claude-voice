# =============================================================================
# Claude Voice configuration.
#
# Copy this file to `.env` (or let `./setup.sh` do it) and tweak as needed.
# Every variable has a safe default; you can leave most of them blank.
#
# Reload after editing: stop `run.sh`, then re-run it. Nothing is hot-reloaded.
# =============================================================================


# ---- Server ---------------------------------------------------------------
# Bind address. 0.0.0.0 = listen on all interfaces (recommended when you plan
# to expose the server via Tailscale Funnel or another reverse proxy).
# Use 127.0.0.1 if you only want local access with no tunnel.
HOST=0.0.0.0

# TCP port for the FastAPI server. If you change this, also update expose.sh
# (it reads PORT from this file, so just editing here is usually enough).
PORT=7878

# Shared-secret password that gates the PWA.
#
# Why this matters: if you expose this server over Tailscale Funnel (or any
# other public tunnel), anyone who learns the URL can drive Claude inside
# your CLAUDE_CWD. AUTH_PASSWORD stops that — the front-end shows a login
# screen, and the WebSocket refuses connections without a valid token.
#
# Two sensible ways to configure this:
#   1. Expose publicly (default): leave the password setup.sh generated for
#      you in place, or replace it with your own. 5 wrong guesses from one
#      IP in 15 minutes triggers a 15-minute lockout.
#   2. Tailnet-only: bind HOST=127.0.0.1, run `tailscale serve` (not funnel)
#      so only your tailnet devices can reach the server, and leave this
#      blank. Auth is skipped entirely since the network is already trusted.
#
# Generate a strong one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(16))'
AUTH_PASSWORD=


# The publicly reachable HTTPS URL of this server, with no trailing slash.
# Used by ./expose.sh to build the QR login link. Leave blank when you use
# Tailscale Funnel — the script auto-detects your MagicDNS name. Set it
# explicitly when you front the server with cloudflared or your own domain:
#   PUBLIC_URL=https://<random>.trycloudflare.com
#   PUBLIC_URL=https://voice.example.com
PUBLIC_URL=


# ---- Claude Code CLI ------------------------------------------------------
# Absolute path to the `claude` executable.
# Leave blank to auto-discover (PATH first, then VS Code / Cursor extensions).
# Recommended install path:
#   npm install -g @anthropic-ai/claude-code && claude login
# Only set this if you have a custom install (e.g. a specific version pinned).
CLAUDE_BIN=

# Working directory that Claude will see and operate in.
#
# THIS IS THE BLAST RADIUS. When CLAUDE_PERMISSION_MODE=bypassPermissions,
# Claude can read, edit, and delete anything inside this directory without
# asking. Point it at a single project, not your home folder.
#
# Examples:
#   CLAUDE_CWD=/home/you/projects/my-app
#   CLAUDE_CWD=/Users/you/code/sandbox
CLAUDE_CWD=

# Force a specific Claude model per turn. Blank uses your account's default.
#   sonnet | haiku | opus
# Opus is best for agentic work but slower and more token-heavy.
# Haiku is fastest; good for quick voice chat where latency trumps depth.
CLAUDE_MODEL=

# How Claude handles tool-use permission prompts.
#   default           — Claude pauses and asks before every tool call.
#   acceptEdits       — auto-approve file edits, still prompt for shell/bash.
#   bypassPermissions — approve everything silently. Required for voice use
#                       because you can't see or tap a prompt from a phone mic.
#   plan              — read-only planning mode; no side effects.
#
# Default here is bypassPermissions because voice mode needs it. If you're
# using the text-mode toggle on a trusted machine and want safety rails,
# switch to `default` or `acceptEdits`.
CLAUDE_PERMISSION_MODE=bypassPermissions


# ---- Whisper (speech-to-text) --------------------------------------------
# Model size vs. quality vs. speed:
#   tiny     — fastest, English-only is okay, multilingual is poor.
#   base     — still lightweight, noticeably better than tiny.
#   small    — good CPU default; multilingual is usable.
#   medium   — great quality on CPU with int8 if you have the cores.
#   large-v3 — best quality, best code-switching (zh/en mix etc.). ~3 GB.
#
# setup.sh writes `large-v3` when it finds a CUDA GPU and `small` otherwise.
WHISPER_MODEL=large-v3

# Device selection:
#   auto — pick CUDA if available, otherwise CPU.
#   cuda — force GPU (errors out if no usable GPU).
#   cpu  — force CPU (useful for debugging or running headless on servers).
WHISPER_DEVICE=auto

# Compute precision. Match this to your device:
#   float16       — best on modern NVIDIA GPUs (3xxx/4xxx/5xxx series).
#   int8_float16  — good middle ground on older GPUs with limited VRAM.
#   int8          — CPU default; fast and low memory.
#   float32       — full precision; rarely needed unless you're debugging.
WHISPER_COMPUTE=float16

# Optional: technical vocabulary hint passed to Whisper as initial context.
# It won't force the tokens but biases decoding toward them, which noticeably
# improves recognition of product names, jargon, and code-switched English
# tech terms inside Chinese/Japanese/Korean speech.
#
# Uncomment and customise if you find Whisper mis-hears a specific word often:
# WHISPER_INITIAL_PROMPT=A technical conversation about Python, FastAPI, React.


# ---- Edge TTS (text-to-speech) -------------------------------------------
# Edge TTS is Microsoft's free cloud voice service. It requires an internet
# connection but no API key. Not officially documented for third-party apps,
# so treat it as best-effort — if Microsoft blocks the endpoint, swap in a
# local TTS (see the roadmap for Piper / CosyVoice).
#
# List all available voices with:
#   edge-tts --list-voices
#
# Handy picks:
#   English (multilingual):  en-US-AvaMultilingualNeural, en-US-AndrewMultilingualNeural
#   English (US, classic):   en-US-AriaNeural, en-US-GuyNeural
#   English (UK):            en-GB-SoniaNeural, en-GB-RyanNeural
#   Chinese (Mandarin):      zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural, zh-CN-YunyangNeural
#   Japanese:                ja-JP-NanamiNeural
#   Spanish:                 es-ES-ElviraNeural
#   Multilingual voices handle mixed-language replies (zh + en) more gracefully
#   than language-locked voices, so they're a good default.
EDGE_VOICE=en-US-AvaMultilingualNeural

# Speaking rate. Positive values speed up, negative slow down.
# Examples: +0%, +10%, +25%, -20%
# +10% is a nice default — a touch faster than natural, so latency feels lower.
EDGE_RATE=+10%
